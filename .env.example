# Copy this file to .env and adjust for your environment.
# .env is gitignored - nothing environment-specific is ever committed.

# ── Ollama (LLM backend) ───────────────────────────────────────────────
# OLLAMA_HOST is the Ollama server URL. It is declared in docker-compose.yaml
# (environment:) - set it there, or override here; this .env value feeds the
# ${OLLAMA_HOST} interpolation in the compose file.
# Running Ollama on the same machine via Docker Desktop (Mac/Windows)? Inside the
# container `localhost` is the container -- use host.docker.internal instead:
#     OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_HOST=http://localhost:11434
# Which models to use is managed in the app at Settings → Models. These two
# only seed the INITIAL defaults on a fresh volume; the UI takes over after.
OLLAMA_MODEL=qwen3:8b
EMBED_MODEL=nomic-embed-text

# ── Clustering / ranking ───────────────────────────────────────────────
# Cosine similarity above which two articles are treated as the same story.
SIM_THRESHOLD=0.74
# Cross-source rank boost = min(BOOST_CAP, BOOST_K * log2(N sources)).
BOOST_CAP=1.5
BOOST_K=0.6

# ── Ingestion ──────────────────────────────────────────────────────────
LOOKBACK_HOURS=36
MAX_ARTICLES=1024
SCORE_CONCURRENCY=4

# ── Schedule (reproduces the old cron: 0 6-22/2 * * *) ─────────────────
# TZ sets the timezone the active-hours window is measured in. Without it the
# container runs in UTC and runs fire in the wrong local window. Declared in
# docker-compose.yaml (defaults to America/Los_Angeles); override here.
TZ=America/Los_Angeles
ACTIVE_START_HOUR=6
ACTIVE_END_HOUR=22
INTERVAL_HOURS=2

# ── Server / data paths ────────────────────────────────────────────────
PORT=8090
STATE_FILE=/data/state.json
DIGEST_FILE=/data/digest.json
FEEDS_FILE=/data/feeds.json
# Categories (labels/colors + the interest descriptions the scorer ranks
# against) live here - edit it to make the app about your own interests. Seeded
# from categories.sample.json on first run; falls back to built-in defaults.
CATEGORIES_FILE=/data/categories.json

# ── Retention ──────────────────────────────────────────────────────────
# History is auto-tracked and aged out after this many days. Read Later is a
# manually-curated list and is never aged out.
HISTORY_RETENTION_DAYS=3

# Inbox retention. Unread stories are carried forward across runs (so a story
# you never read doesn't vanish when its feed rotates it out) and pruned by a
# rank-weighted lifespan held inside a [floor, ceiling] band. Read stories are
# vacated; History keeps its own copy. Stories = de-duplicated clusters.
RETAIN_FLOOR=25                # keep at least this many unread stories if available
RETAIN_CEILING=60             # never carry more than this; lowest-ranked fall off
RETAIN_BASE_TTL_HOURS=24      # lifespan of the lowest-ranked story
RETAIN_MAX_TTL_HOURS=72       # lifespan of the highest-ranked story
RETAIN_HARD_MAX_AGE_HOURS=120 # absolute cutoff; overrides the floor
